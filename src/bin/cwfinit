#!/usr/bin/env php
<?php
echo "CWF-PHP - Project initialisation script" . PHP_EOL;
echo "=======================================" . PHP_EOL;
echo "1. Set project directory" . PHP_EOL;

$wrkDir = getcwd();
$protocol = "https";
$hostname = gethostname();
$port = 443;
$path = "/";

echo "Run in current directory [{$wrkDir}]?" . PHP_EOL;

step1:
    $resp = readline("(y/n) [y]: ");
    switch ($resp) {
        case "":
        case "y":
            goto step2;
        case "n":
            break;
        default:
            goto step1;
    }

step1a:
    $resp = readline("Please type working directory: ");
    if (is_dir($resp)) {
        $wrkDir = $resp;
    } else {
        echo "Invalid directory. Please type again" . PHP_EOL;
        goto step1a;
    }

step2:
    if (!is_writable($wrkDir)) {
        echo "Directory [{$wrkDir}] is not writeable. Aborted." . PHP_EOL;
        goto end;
    }
    echo "2. Set directory names" . PHP_EOL;
    echo "Use default ones?" . PHP_EOL;

step2a:
    $resp = readline("(y/n) [y]: ");
    switch ($resp) {
        case "":
        case "y":
            goto step3;
        case "n":
            break;
        default:
            goto step2a;
    }

step3:
    echo "3. HTTP URL configuration" . PHP_EOL;
    $resp = readline("Protocol (https/http)? [{$protocol}]: ");
    $resp = readline("Hostname? [{$hostname}]: ");
    $resp = readline("Port? [{$port}]: ");
    $resp = readline("Application URL path? [{$path}]: ");
end:
    echo PHP_EOL;